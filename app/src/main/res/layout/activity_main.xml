<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2A1A0A"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <!-- Game Info Panel -->
    <LinearLayout
        android:id="@+id/gameInfoPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/info_panel_background"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/gameModeText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="start"
                android:text="模式: 玩家 vs AI"
                android:textSize="14sp"
                android:textColor="#C0A880"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/moveCountText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:text="回合: 0"
                android:textSize="14sp"
                android:textColor="#C0A880"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:letterSpacing="0.05" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/redScoreText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="start"
                android:text="红方: 0"
                android:textSize="16sp"
                android:textColor="#E05040"
                android:textStyle="bold"
                android:fontFamily="serif" />

            <TextView
                android:id="@+id/gameTimeText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="00:00"
                android:textSize="16sp"
                android:textColor="#D4A860"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/blackScoreText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:text="黑方: 0"
                android:textSize="16sp"
                android:textColor="#E0D0C0"
                android:textStyle="bold"
                android:fontFamily="serif" />
        </LinearLayout>
    </LinearLayout>

    <!-- Status with turn indicator dot -->
    <LinearLayout
        android:id="@+id/statusContainer"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="16dp"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/gameInfoPanel">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:id="@+id/turnIndicatorDot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/turn_indicator_dot" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="红方走棋"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#F0E0C0"
                android:fontFamily="serif"
                android:shadowColor="#80000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="3" />
        </LinearLayout>

        <!-- AI thinking dots -->
        <LinearLayout
            android:id="@+id/aiThinkingIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:visibility="gone">

            <View
                android:id="@+id/thinkingDot1"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_margin="3dp"
                android:background="@drawable/thinking_dot" />

            <View
                android:id="@+id/thinkingDot2"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_margin="3dp"
                android:background="@drawable/thinking_dot" />

            <View
                android:id="@+id/thinkingDot3"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_margin="3dp"
                android:background="@drawable/thinking_dot" />
        </LinearLayout>
    </LinearLayout>

    <!-- Black captured pieces (touching top of board) -->
    <HorizontalScrollView
        android:id="@+id/blackCapturedContainer"
        android:layout_width="0dp"
        android:layout_height="26dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:scrollbars="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/boardView">

        <LinearLayout
            android:id="@+id/blackCapturedPieces"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical" />
    </HorizontalScrollView>

    <com.yingwang.chinesechess.ui.BoardView
        android:id="@+id/boardView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        app:layout_constraintBottom_toTopOf="@+id/moveHistoryContainer"
        app:layout_constraintDimensionRatio="0.9:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/statusContainer"
        app:layout_constraintVertical_bias="0.0" />

    <!-- Red captured pieces (touching bottom of board) -->
    <HorizontalScrollView
        android:id="@+id/redCapturedContainer"
        android:layout_width="0dp"
        android:layout_height="26dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:scrollbars="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/boardView">

        <LinearLayout
            android:id="@+id/redCapturedPieces"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical" />
    </HorizontalScrollView>

    <ScrollView
        android:id="@+id/moveHistoryContainer"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="6dp"
        android:background="@drawable/info_panel_background"
        app:layout_constraintBottom_toTopOf="@+id/buttonContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/moveHistoryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="棋谱:"
            android:textSize="13sp"
            android:textColor="#B0956A"
            android:fontFamily="serif"
            android:letterSpacing="0.02"
            android:lineSpacingExtra="2dp" />
    </ScrollView>

    <!-- Buttons row -->
    <LinearLayout
        android:id="@+id/buttonContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/newGameButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:text="新游戏"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#F0E0C0"
            android:fontFamily="serif"
            android:letterSpacing="0.1"
            android:background="@drawable/button_selector" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/hintButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:text="提  示"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#F0E0C0"
            android:fontFamily="serif"
            android:letterSpacing="0.1"
            android:background="@drawable/button_selector" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/undoButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:text="悔  棋"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#F0E0C0"
            android:fontFamily="serif"
            android:letterSpacing="0.1"
            android:background="@drawable/button_selector" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/moreButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:text="更  多"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#F0E0C0"
            android:fontFamily="serif"
            android:letterSpacing="0.1"
            android:background="@drawable/button_selector" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
