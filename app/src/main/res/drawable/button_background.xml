<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bottom shadow layer -->
    <item android:top="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#3A2010" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <!-- Main button body -->
    <item android:bottom="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#5A3820"
                android:centerColor="#7A5438"
                android:endColor="#8B6442"
                android:type="linear" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <!-- Top highlight -->
    <item android:bottom="3dp" android:left="2dp" android:right="2dp" android:top="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#00FFFFFF"
                android:endColor="#18FFFFFF"
                android:type="linear" />
            <corners android:radius="9dp" />
        </shape>
    </item>
</layer-list>
